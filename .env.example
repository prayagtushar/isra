# ISRA environment variables — copy to .env and fill in real values.
# .env is gitignored; never commit real secrets.
#
# IMPORTANT: the API (apps/api) and retrieval lib read settings with the
# `ISRA_` prefix (pydantic-settings env_prefix). The ingest job reads the
# UNPREFIXED `DATABASE_URL`. Both are listed below — set the ones each
# component needs.

# ─────────────────────────────────────────────────────────────────────────
# Database (Postgres + pgvector)
# ─────────────────────────────────────────────────────────────────────────
# Used by the API and the retrieval library.
ISRA_DATABASE_URL=postgresql://isra:isra@localhost:5432/isra
# Used by the ingest job (apps/ingest). Point at the same database.
DATABASE_URL=postgresql://isra:isra@localhost:5432/isra

# ─────────────────────────────────────────────────────────────────────────
# LLM (OpenRouter via the openrouter SDK) — required for POST /chat
# ─────────────────────────────────────────────────────────────────────────
ISRA_OPENROUTER_API_KEY=sk-or-...
# Model for /chat. Use an OpenRouter ":free" model to stay at $0 (the :free
# suffix is required — without it OpenRouter bills against credits). The free
# roster rotates; see https://openrouter.ai/models?max_price=0
ISRA_LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ─────────────────────────────────────────────────────────────────────────
# Langfuse tracing (optional). Tracing is disabled unless BOTH keys are set.
# ─────────────────────────────────────────────────────────────────────────
ISRA_LANGFUSE_PUBLIC_KEY=
ISRA_LANGFUSE_SECRET_KEY=
ISRA_LANGFUSE_HOST=https://cloud.langfuse.com

# ─────────────────────────────────────────────────────────────────────────
# Evals (apps/evals) — only needed when running `bun run eval`
# ─────────────────────────────────────────────────────────────────────────
# ISRA_OPENROUTER_API_KEY is reused (see above).
ISRA_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─────────────────────────────────────────────────────────────────────────
# Web app (apps/web) — server-side only, required in production
# ─────────────────────────────────────────────────────────────────────────
# Full base URL of the deployed FastAPI service (no trailing slash).
API_URL=http://localhost:8000
